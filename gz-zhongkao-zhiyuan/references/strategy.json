{
  "strategy": "广州中考志愿填报策略指南",
  "last_updated": "2026-04-27",
  "steps": [
    {
      "step": 1,
      "title": "确定自身成绩区间",
      "detail": "参考一模、二模成绩，结合中考成绩预测，确定自己的大致分数区间（±20分）"
    },
    {
      "step": 2,
      "title": "查阅梯度控制线",
      "detail": "确认自己处于哪个梯度控制线区间，这决定了可以报考哪类学校"
    },
    {
      "step": 3,
      "title": "逐批次规划志愿",
      "detail": "第一批次考虑特长/自主招生机会；第二批次务必认真利用名额分配；第三批次冲刺目标校；第四批次兜底"
    },
    {
      "step": 4,
      "title": "志愿梯度原则",
      "detail": "同一批次内志愿要有梯度，第一志愿可略微冲一下，后续志愿要稳妥"
    },
    {
      "step": 5,
      "title": "名额分配批次策略",
      "detail": "不要轻易放弃名额分配批次，即使目标是顶尖高中，也可用名额分配填报第三批次的目标校"
    }
  ],
